# API (server/TurnoverLog.Api)
ConnectionStrings__DefaultConnection=Server=localhost;Database=TurnoverLog;Trusted_Connection=True;TrustServerCertificate=True
Jwt__Key=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=TurnoverLog
Jwt__Audience=TurnoverLogClient

# Client (client/.env) — leave empty in dev to use Vite proxy
VITE_API_URL=

# Email (optional — empty SmtpHost writes .eml files to email-outbox/)
# Email__SmtpHost=
# Email__SmtpUser=
# Email__SmtpPassword=
# Email__DefaultSupervisorEmail=supervisor@turnover.local

# Demo account (seeded on first API run)
# demo@turnover.local / Demo1234!
# Supervisor for demo user: supervisor@turnover.local
